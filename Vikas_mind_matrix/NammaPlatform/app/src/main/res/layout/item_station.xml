<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:background="@drawable/bg_card_blue"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:padding="16dp"
    android:minHeight="72dp">

    <TextView
        android:id="@+id/tvCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@color/brand_yellow"
        android:textColor="@color/brand_blue_dark"
        android:textStyle="bold"
        android:padding="8dp"
        android:textSize="14sp"
        tools:text="MYS"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvNameKn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textColor="@color/brand_yellow"
        android:textSize="20sp"
        android:textStyle="bold"
        tools:text="ಮೈಸೂರು ಜಂಕ್ಷನ್"
        app:layout_constraintTop_toTopOf="@id/tvCode"
        app:layout_constraintStart_toEndOf="@id/tvCode"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvNameEn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="14sp"
        tools:text="Mysuru Junction"
        app:layout_constraintTop_toBottomOf="@id/tvNameKn"
        app:layout_constraintStart_toStartOf="@id/tvNameKn"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
