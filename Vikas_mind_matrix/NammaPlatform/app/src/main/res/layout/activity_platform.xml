<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_blue_dark"
    android:padding="12dp">

    <!-- Station header (Kannada-first) -->
    <TextView
        android:id="@+id/tvStationKn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/brand_yellow"
        android:textSize="26sp"
        android:textStyle="bold"
        tools:text="ಮೈಸೂರು ಜಂಕ್ಷನ್"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvStationEn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="14sp"
        tools:text="Mysuru Junction"
        app:layout_constraintTop_toBottomOf="@id/tvStationKn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- "Next 3 trains" label -->
    <TextView
        android:id="@+id/tvNextTrainsLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/label_next_trains"
        android:textColor="@color/brand_yellow"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvStationEn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Train list (max 3) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTrains"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:nestedScrollingEnabled="false"
        app:layout_constraintTop_toBottomOf="@id/tvNextTrainsLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:itemCount="3" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp"
        android:text="@string/msg_no_trains"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rvTrains"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Coach layout label -->
    <TextView
        android:id="@+id/tvSelectedTrain"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/brand_yellow"
        android:textSize="16sp"
        android:textStyle="bold"
        tools:text="ಕಾವೇರಿ ಎಕ್ಸ್‌ಪ್ರೆಸ್ — ಪ್ಲಾಟ್‌ಫಾರ್ಮ್ 2"
        app:layout_constraintTop_toBottomOf="@id/rvTrains"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvCoachHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="@string/hint_coach_strip"
        android:textColor="@color/white"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/tvSelectedTrain"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Coach strip (custom horizontal scroll view) -->
    <com.nammaplatform.app.ui.platform.CoachStripView
        android:id="@+id/coachStrip"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@color/brand_blue"
        android:minHeight="80dp"
        app:layout_constraintTop_toBottomOf="@id/tvCoachHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Help-Me / Speak button — large, yellow, central -->
    <Button
        android:id="@+id/btnHelp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_button_yellow"
        android:minHeight="64dp"
        android:padding="12dp"
        android:text="@string/btn_help_speak"
        android:textColor="@color/brand_blue_dark"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/coachStrip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
