<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme. -->
    <style name="Theme.NammaPlatform" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand colour -->
        <item name="colorPrimary">@color/brand_blue_dark</item>
        <item name="colorPrimaryVariant">@color/brand_blue</item>
        <item name="colorOnPrimary">@color/brand_yellow</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/brand_yellow</item>
        <item name="colorSecondaryVariant">@color/brand_yellow_pressed</item>
        <item name="colorOnSecondary">@color/brand_blue_dark</item>

        <!-- Status bar -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/brand_blue_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/brand_blue_dark</item>
    </style>

</resources>
