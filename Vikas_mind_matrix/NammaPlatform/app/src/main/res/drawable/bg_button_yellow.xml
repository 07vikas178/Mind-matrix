<?xml version="1.0" encoding="utf-8"?>
<!-- Big yellow Help-Me button -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_yellow_pressed" />
            <stroke android:width="3dp" android:color="@color/brand_blue_dark" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/brand_yellow" />
            <stroke android:width="3dp" android:color="@color/brand_blue_dark" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
